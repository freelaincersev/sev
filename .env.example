# Copy to .env.local and fill in.
#
# LOCAL DEV: run `supabase start`, then `supabase status -o env` and copy
#   ANON_KEY        -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#   SERVICE_ROLE_KEY-> SUPABASE_SERVICE_ROLE_KEY
#   API_URL         -> NEXT_PUBLIC_SUPABASE_URL
#
# PRODUCTION (Vercel): use your Supabase project's URL + keys from the
# Supabase dashboard (Project Settings → API). Set these as Vercel env vars.

# Public — safe to expose to the browser (RLS protects the data).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — full DB access, bypasses RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# LLM / embeddings providers (strategy §6.1 — OpenAI embeddings + LLM router).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
